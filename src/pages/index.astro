---
import Base from '@/layouts/Base.astro'
import { PROGRAMAS } from '@/lib/constants'
import { getCloudcasts, formatDuration, formatDate } from '@/lib/mixcloud'

// Últimos episodios de la radio
const episodios = await getCloudcasts(undefined, { limit: 12, order: 'latest' })
---

<Base>

  <!-- HERO — primera pantalla -->
  <section class="flex flex-col items-center justify-center min-h-full px-6 pt-6 pb-12 text-center">

    <img
      src="/assets/GIF RADIO TRANSPARENTE.GIF"
      autoplay
      muted
      loop
      playsinline
      aria-label="Radio Elástica"
      class="w-[60rem] max-w-full mx-auto mb-4"
    ></img>
 <img
      src="/assets/Descripción radio sin fondo.PNG"
      class="w-[44rem] max-w-full mx-auto mb-2"
    />


    {episodios.length === 0 ? (
      <span class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest
                   text-white/40 border border-white/20 px-6 py-3 rounded-full">
        Próximamente
      </span>
    ) : (
      <button
        id="scroll-down"
        class="text-white/40 hover:text-white/70 transition-colors animate-bounce"
        aria-label="Ver últimos episodios"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M7 10l5 5 5-5"/>
        </svg>
      </button>
    )}

  </section>

  <!-- LATEST — aparecen al hacer scroll -->
  {episodios.length > 0 && (
    <section id="ultimos" class="px-6 py-12">

      <h2 class="font-display italic text-4xl text-white text-center mb-6">
        ✦ ✦
      </h2>

      <a
        href="https://www.mixcloud.com/live/radioelastica/"
        target="_blank"
        rel="noopener noreferrer"
        class="block mx-auto mb-10 w-fit"
        aria-label="Escúchanos aquí"
      >
        <img
          src="/assets/ESCÚCHANOS AQUÍ GIF SIN FONDO.GIF"
          alt="Escúchanos aquí"
          class="w-[20rem] max-w-full mx-auto"
        />
      </a>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
        {episodios.map(ep => (
          <button
            class="flex items-center gap-3 bg-white/5 border border-white/10
                   rounded-lg p-3 text-left hover:bg-white/10 transition-colors
                   ep-play-btn"
            data-key={ep.key}
            data-title={ep.name}
            data-cover={ep.pictures?.['320wx320h'] ?? ep.pictures?.large ?? '/assets/logo-square.jpg'}
            data-duration={String(ep.audio_length)}
          >
            <img
              src={ep.pictures?.['320wx320h'] ?? ep.pictures?.large ?? '/assets/logo-square.jpg'}
              alt={ep.name}
              class="w-14 h-14 rounded object-cover flex-shrink-0"
            />
            <div class="flex-1 min-w-0">
              <p class="text-sm text-white font-medium truncate">{ep.name}</p>
              <p class="text-xs text-white/40 mt-0.5">
                {formatDate(ep.created_time)} · {formatDuration(ep.audio_length)}
              </p>
            </div>
            <svg class="w-5 h-5 text-white/40 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path d="M6.5 3.5l10 6.5-10 6.5V3.5z"/>
            </svg>
          </button>
        ))}
      </div>

    </section>
  )}

</Base>

<script>
  import { playTrack } from '@/lib/widget'
  import type { PlayerTrack } from '@/lib/types'

  // Scroll suave al clickar la flecha
  document.getElementById('scroll-down')?.addEventListener('click', () => {
    document.getElementById('ultimos')?.scrollIntoView({ behavior: 'smooth' })
  })

  // Play al clickar episodio
  document.querySelectorAll('.ep-play-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement
      const track: PlayerTrack = {
        key:      el.dataset.key!,
        title:    el.dataset.title!,
        dj:       '',
        cover:    el.dataset.cover!,
        duration: Number(el.dataset.duration),
        isLive:   false,
      }
      playTrack(track)
    })
  })
</script>

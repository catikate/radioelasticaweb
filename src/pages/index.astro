---
import Base from '@/layouts/Base.astro'
---

<Base>

  <!-- HERO -->
  <section class="flex flex-col items-center justify-center min-h-full px-6 py-12 text-center">

    <img
      src="/assets/logo-sin-fondo.png"
      alt="Radio Elástica"
      class="w-[36rem] max-w-full mx-auto mb-12"
    />

    <p class="text-white/60 text-sm uppercase tracking-[0.25em] mb-3">
      Emisora online independiente · Barcelona
    </p>

    <p class="text-white font-serif text-3xl italic mb-10">
      Miércoles · 11:11
    </p>

    <span class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest
                 text-white/40 border border-white/20 px-6 py-3 rounded-full">
      Próximamente
    </span>

  </section>

</Base>

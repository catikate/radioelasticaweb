---
import Base from '@/layouts/Base.astro'
import { PROGRAMAS } from '@/lib/constants'
---

<Base title="Programas">

  <section class="px-6 py-12">

    <h1 class="font-display italic text-3xl text-white text-center mb-2">
      ✦ Programas ✦
    </h1>

    <p class="text-white/50 text-xs uppercase tracking-[0.25em] text-center mb-12">
      Temporada 1
    </p>

    <div class="flex flex-col items-center gap-12 max-w-sm mx-auto">
      {PROGRAMAS.map((p) => (
        <a
          href={`/programas/${p.slug}`}
          class="block hover:scale-[1.02] transition-transform w-full"
        >
          <img
            src={p.foto}
            alt={p.programa}
            class="w-full rounded-lg object-cover"
            onerror="this.onerror=null;this.src='/assets/logo-square.jpg'"
          />
        </a>
      ))}
    </div>

  </section>

</Base>

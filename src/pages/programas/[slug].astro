---
import Base from '@/layouts/Base.astro'
import { PROGRAMAS } from '@/lib/constants'
import { getCloudcasts, formatDuration, formatDate } from '@/lib/mixcloud'

export function getStaticPaths() {
  return PROGRAMAS.map(p => ({
    params: { slug: p.slug },
    props:  { programa: p },
  }))
}

const { programa } = Astro.props

// Fetch episodios usando el primer tag identificador (no temporada)
const mainTag = programa.tags.find((t: string) => t.startsWith('programa-'))
  ?? programa.tags.find((t: string) => t !== 'temporada-1')!
const episodios = await getCloudcasts(undefined, { tags: mainTag, limit: 50, order: 'latest' })
---

<Base title={programa.programa}>

  <section class="px-6 py-12 max-w-3xl mx-auto">

    <!-- Cabecera -->
    <div class="flex flex-col items-center gap-8 mb-12">
      <div class="bg-white p-3 pb-8 shadow-sm rotate-[-1deg]">
        <img
          src={programa.foto}
          alt={programa.programa}
          class="w-64 sm:w-80 aspect-[3/4] object-cover"
          onerror="this.onerror=null;this.src='/assets/logo-square.jpg'"
        />
      </div>
      <div class="text-center">
        <h1 class="font-display italic text-4xl text-white">
          {programa.programa}
        </h1>
        <p class="text-white/60 text-lg mt-3">
          {programa.tipo === 'residente'
            ? `w/ ${programa.residente}`
            : programa.residente === 'Varios'
              ? 'Anfitrión diferente cada episodio'
              : `Conduce: ${programa.residente}`}
        </p>
        <p class="text-white/50 text-2xl mt-4 leading-relaxed max-w-xl mx-auto not-italic" style="font-style: normal;">
          {programa.descripcion}
        </p>
      </div>
    </div>

    <!-- Lista de episodios -->
    <h2 class="font-display italic text-2xl text-white mb-6">
      ✦ Episodios
    </h2>

    {episodios.length === 0 ? (
      <p class="text-white/50 text-base italic">
        Próximamente — los episodios aparecerán aquí cuando se publiquen en Mixcloud.
      </p>
    ) : (
      <div class="space-y-3">
        {episodios.map(ep => (
          <button
            class="w-full flex items-center gap-3 bg-white/5 border border-white/10
                   rounded-lg p-3 text-left hover:bg-white/10 transition-colors
                   ep-play-btn"
            data-key={ep.key}
            data-title={ep.name}
            data-cover={ep.pictures?.['320wx320h'] ?? ep.pictures?.large ?? '/assets/logo-square.jpg'}
            data-duration={String(ep.audio_length)}
          >
            <img
              src={ep.pictures?.['320wx320h'] ?? ep.pictures?.large ?? '/assets/logo-square.jpg'}
              alt={ep.name}
              class="w-12 h-12 rounded object-cover flex-shrink-0"
            />
            <div class="flex-1 min-w-0">
              <p class="text-sm text-white font-medium truncate">{ep.name}</p>
              <p class="text-xs text-white/40 mt-0.5">
                {formatDate(ep.created_time)} · {formatDuration(ep.audio_length)}
              </p>
            </div>
            <svg class="w-5 h-5 text-white/40 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path d="M6.5 3.5l10 6.5-10 6.5V3.5z"/>
            </svg>
          </button>
        ))}
      </div>
    )}

  </section>

</Base>

<script>
  import { playTrack } from '@/lib/widget'
  import type { PlayerTrack } from '@/lib/types'

  if (!(window as any).__epPlayInit) {
    ;(window as any).__epPlayInit = true
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as Element).closest<HTMLElement>('.ep-play-btn')
      if (!btn) return
      const track: PlayerTrack = {
        key:      btn.dataset.key!,
        title:    btn.dataset.title!,
        dj:       '',
        cover:    btn.dataset.cover!,
        duration: Number(btn.dataset.duration),
        isLive:   false,
      }
      playTrack(track)
    })
  }
</script>

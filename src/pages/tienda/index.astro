---
import Base from '@/layouts/Base.astro'
---

<Base title="Tienda">

  <section class="px-4 sm:px-6 py-10 sm:py-12 max-w-3xl mx-auto">

    <h1 class="text-xs sm:text-sm font-bold uppercase tracking-widest text-white/50 mb-8 sm:mb-10">
      Tienda
    </h1>

    <div class="flex flex-col items-center justify-center py-20 sm:py-24 text-center">
      <p class="text-white/30 text-sm sm:text-base uppercase tracking-widest mb-3">
        Próximamente
      </p>
      <p class="text-white/20 text-xs sm:text-sm">Estamos preparando algo especial</p>
    </div>

  </section>

</Base>

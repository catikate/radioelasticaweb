---
import Base from '@/layouts/Base.astro'
import { PROGRAMAS, toSlug } from '@/lib/constants'
import { getCloudcasts, formatDuration, formatDate } from '@/lib/mixcloud'

// Generar una ruta por cada residente único
export function getStaticPaths() {
  const seen = new Set<string>()
  return PROGRAMAS
    .filter(p => {
      if (p.residente === 'Varios' || seen.has(p.residente)) return false
      seen.add(p.residente)
      return true
    })
    .map(p => ({
      params: { slug: toSlug(p.residente) },
      props:  { residente: p.residente },
    }))
}

const { residente } = Astro.props

// Todos los programas de este residente
const programas = PROGRAMAS.filter(p => p.residente === residente)

// Fetch de episodios agrupados por programa
// Preferir tag programa-* para no mezclar episodios de otros programas
const programasConEpisodios = await Promise.all(
  programas.map(async (p) => {
    const mainTag = p.tags.find((t: string) => t.startsWith('programa-'))
      ?? p.tags.find((t: string) => t !== 'temporada-1')!
    const episodios = await getCloudcasts(undefined, { tags: mainTag, limit: 50, order: 'latest' })
    return { ...p, episodios }
  })
)

// Buscar apariciones en programas rotativos (ej: Una Mañana Elástica)
const residenteTag = programas
  .flatMap(p => [...p.tags])
  .find((t: string) => t.startsWith('residente-'))

let otrasParticipaciones: Awaited<ReturnType<typeof getCloudcasts>> = []
if (residenteTag) {
  const allByResidente = await getCloudcasts(undefined, { tags: residenteTag, limit: 50, order: 'latest' })
  const shownKeys = new Set(programasConEpisodios.flatMap(p => p.episodios.map(e => e.key)))
  otrasParticipaciones = allByResidente.filter(ep => !shownKeys.has(ep.key))
}

const slug = Astro.params.slug!
const fotoResidente = `/assets/residentes/${slug}.jpg`
---

<Base title={residente}>

  <section class="px-6 py-12 max-w-3xl mx-auto">

    <!-- Cabecera del residente -->
    <div class="flex flex-col sm:flex-row items-center gap-6 mb-10">
      <div class="bg-white p-2 pb-6 shadow-sm rotate-[-1deg] flex-shrink-0">
        <img
          src={fotoResidente}
          alt={residente}
          class="w-40 aspect-[3/4] object-cover"
          onerror="this.onerror=null;this.src='/assets/logo-square.jpg'"
        />
      </div>
      <div class="text-center sm:text-left">
        <h1 class="font-display italic text-3xl text-white">{residente}</h1>
        <p class="text-white/50 text-sm mt-2">
          {programas.map(p => p.programa).join(' · ')}
        </p>
        <p class="text-white/40 text-xs mt-1">
          {programas.map(p => p.descripcion).join(' — ')}
        </p>
      </div>
    </div>

    <!-- Programas con sus episodios -->
    {programasConEpisodios.map(prog => (
      <div class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <img
            src={prog.foto}
            alt={prog.programa}
            class="w-10 h-10 rounded object-cover flex-shrink-0"
            onerror="this.onerror=null;this.src='/assets/logo-square.jpg'"
          />
          <h2 class="font-display italic text-xl text-white">
            ✦ {prog.programa}
          </h2>
        </div>

        {prog.episodios.length === 0 ? (
          <p class="text-white/40 text-sm italic ml-[52px]">
            Próximamente — los episodios aparecerán aquí cuando se publiquen en Mixcloud.
          </p>
        ) : (
          <div class="space-y-3">
            {prog.episodios.map(ep => (
              <button
                class="w-full flex items-center gap-3 bg-white/5 border border-white/10
                       rounded-lg p-3 text-left hover:bg-white/10 transition-colors
                       ep-play-btn"
                data-key={ep.key}
                data-title={ep.name}
                data-cover={ep.pictures?.['320wx320h'] ?? ep.pictures?.large ?? '/assets/logo-square.jpg'}
                data-duration={String(ep.audio_length)}
              >
                <img
                  src={ep.pictures?.['320wx320h'] ?? ep.pictures?.large ?? '/assets/logo-square.jpg'}
                  alt={ep.name}
                  class="w-12 h-12 rounded object-cover flex-shrink-0"
                />
                <div class="flex-1 min-w-0">
                  <p class="text-sm text-white font-medium truncate">{ep.name}</p>
                  <p class="text-xs text-white/40 mt-0.5">
                    {formatDate(ep.created_time)} · {formatDuration(ep.audio_length)}
                  </p>
                </div>
                <svg class="w-5 h-5 text-white/40 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M6.5 3.5l10 6.5-10 6.5V3.5z"/>
                </svg>
              </button>
            ))}
          </div>
        )}
      </div>
    ))}

    {/* Apariciones en programas rotativos */}
    {otrasParticipaciones.length > 0 && (
      <div class="mb-10">
        <h2 class="font-display italic text-xl text-white mb-4">
          ✦ Otras participaciones
        </h2>

        <div class="space-y-3">
          {otrasParticipaciones.map(ep => (
            <button
              class="w-full flex items-center gap-3 bg-white/5 border border-white/10
                     rounded-lg p-3 text-left hover:bg-white/10 transition-colors
                     ep-play-btn"
              data-key={ep.key}
              data-title={ep.name}
              data-cover={ep.pictures?.['320wx320h'] ?? ep.pictures?.large ?? '/assets/logo-square.jpg'}
              data-duration={String(ep.audio_length)}
            >
              <img
                src={ep.pictures?.['320wx320h'] ?? ep.pictures?.large ?? '/assets/logo-square.jpg'}
                alt={ep.name}
                class="w-12 h-12 rounded object-cover flex-shrink-0"
              />
              <div class="flex-1 min-w-0">
                <p class="text-sm text-white font-medium truncate">{ep.name}</p>
                <p class="text-xs text-white/40 mt-0.5">
                  {formatDate(ep.created_time)} · {formatDuration(ep.audio_length)}
                </p>
              </div>
              <svg class="w-5 h-5 text-white/40 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path d="M6.5 3.5l10 6.5-10 6.5V3.5z"/>
              </svg>
            </button>
          ))}
        </div>
      </div>
    )}

  </section>

</Base>

<script>
  import { playTrack } from '@/lib/widget'
  import type { PlayerTrack } from '@/lib/types'

  if (!(window as any).__epPlayInit) {
    ;(window as any).__epPlayInit = true
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as Element).closest<HTMLElement>('.ep-play-btn')
      if (!btn) return
      const track: PlayerTrack = {
        key:      btn.dataset.key!,
        title:    btn.dataset.title!,
        dj:       '',
        cover:    btn.dataset.cover!,
        duration: Number(btn.dataset.duration),
        isLive:   false,
      }
      playTrack(track)
    })
  }
</script>

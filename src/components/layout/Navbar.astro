---
import { ASSETS } from '@/lib/constants'

const links = [
  { href: '/programas',  img: ASSETS.navButtons.programas,  alt: 'Programas'  },
  { href: '/residentes', img: ASSETS.navButtons.residentes, alt: 'Residentes' },
  { href: '/calendario', img: ASSETS.navButtons.calendario, alt: 'Calendario' },
  { href: '/tienda',     img: ASSETS.navButtons.tienda,     alt: 'Tienda'     },
]

const currentPath = Astro.url.pathname
---

<nav
  class="fixed top-0 left-0 right-0 z-50 h-nav
         bg-re-blue border-b border-white/10
         flex items-center justify-center gap-2 px-4"
>
  {links.map(({ href, img, alt }) => (
    <a
      href={href}
      class:list={[
        'flex items-center justify-center h-10 px-3 rounded transition-opacity',
        currentPath.startsWith(href)
          ? 'opacity-100'
          : 'opacity-50 hover:opacity-80'
      ]}
    >
      <img
        src={img}
        alt={alt}
        class="h-7 w-auto"
      />
    </a>
  ))}
</nav>

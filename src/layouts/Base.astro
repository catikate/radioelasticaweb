---
import '../styles/global.css'
import { ViewTransitions } from 'astro:transitions'
import Navbar     from '@/components/layout/Navbar.astro'
import LivePlayer  from '@/components/player/LivePlayer'
import { getLatestCloudcast } from '@/lib/mixcloud'
import { widgetSrc } from '@/lib/mixcloud'

interface Props {
  title?:       string
  description?: string
  ogImage?:     string
}

const {
  title       = 'Radio Elástica',
  description = 'Emisora online independiente desde Barcelona. Miércoles 11:11.',
  ogImage     = '/assets/logo-square.jpg',
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://radioelastica.com')
const latest = await getLatestCloudcast()
const initialSrc = widgetSrc(latest?.key)
---

<!doctype html>
<html lang="es">
<head>
 <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="google-site-verification" content="vWaTl3dZboH6NjzwY1eJKFBkSrBDwfV5ci0zyY5m8d8" />
  <link rel="icon" type="image/jpeg" href="/assets/logo-square.jpg" />
  <link rel="canonical" href={canonicalURL} />

  <title>{title === 'Radio Elástica' ? title : `${title} — Radio Elástica`}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Tipografía — Playfair Display -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />

  <ViewTransitions />
</head>

<body class="bg-re-blue text-white font-display">

  <!-- NAV — fijo en la parte superior -->
  <Navbar />

  <!-- CONTENIDO — zona con scroll entre nav y reproductor -->
  <main id="content" class="no-scrollbar">
    <slot />
  </main>

  <!-- BOTÓN HOME FLOTANTE — solo fuera de la home -->
  <a
    id="home-fab"
    href="/"
    class="fixed z-50 bottom-[104px] right-5
           w-12 h-12 rounded-full bg-white/10 border border-white/20
           flex items-center justify-center
           hover:bg-white/20 transition-colors
           hidden"
    aria-label="Volver al inicio"
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 10H5"/>
      <path d="M10 5l-5 5 5 5"/>
    </svg>
  </a>
<!-- BANNER EN VIVO -->
<LivePlayer client:load transition:persist />

<!-- REPRODUCTOR — creado imperativament fuera de <body> para que el swap
     de Astro View Transitions nunca lo toque. Los iframes se reinician al
     salir del DOM; viviendo en <html> (no en <body>) nunca se desconectan. -->
<script is:inline define:vars={{ initialSrc }}>
  (function () {
    if (document.getElementById('mc-widget')) return;

    var iframe = document.createElement('iframe');
    iframe.id    = 'mc-widget';
    iframe.src   = initialSrc;
    iframe.allow = 'autoplay';
    iframe.style.cssText = 'width:100%;height:62px;border:none;';

    var bar = document.createElement('div');
    bar.id = 'player-bar';
    bar.style.cssText = [
      'position:fixed', 'bottom:0', 'left:0', 'right:0',
      'height:84px', 'z-index:50',
      'display:flex', 'align-items:center',
      'background:#1a1a2e',
      'border-top:2px solid #3878F5',
    ].join(';');

    bar.appendChild(iframe);
    document.documentElement.appendChild(bar);
  })();
</script>

  <!-- Swipe derecha para volver a home (móvil) + mostrar/ocultar FAB -->
  <script is:inline>
    (function() {
      // Mostrar/ocultar FAB según la ruta actual — se llama en cada navegación
      function setupFab() {
        var fab = document.getElementById('home-fab');
        if (!fab) return;
        if (window.location.pathname !== '/') {
          var path = window.location.pathname.replace(/\/$/, '');
          var parts = path.split('/').filter(Boolean);
          fab.href = '/';
          // /programas/slug → /programas, /residentes/slug → /residentes
          if (parts.length >= 2 && (parts[0] === 'programas' || parts[0] === 'residentes')) {
            fab.href = '/' + parts[0];
          }
          fab.classList.remove('hidden');
        } else {
          fab.classList.add('hidden');
        }
      }

      setupFab();
      document.addEventListener('astro:page-load', setupFab);

      // Swipe right → home — se inicializa una sola vez
      if (!window.__swipeInitialized) {
        window.__swipeInitialized = true;
        var startX = 0;
        var startY = 0;
        document.addEventListener('touchstart', function(e) {
          startX = e.touches[0].clientX;
          startY = e.touches[0].clientY;
        }, { passive: true });
        document.addEventListener('touchend', function(e) {
          var dx = e.changedTouches[0].clientX - startX;
          var dy = Math.abs(e.changedTouches[0].clientY - startY);
          if (dx > 100 && dy < 80 && startX < 40 && window.location.pathname !== '/') {
            var fab = document.getElementById('home-fab');
            window.location.href = fab ? fab.href : '/';
          }
        }, { passive: true });
      }
    })();
  </script>

</body>
</html>

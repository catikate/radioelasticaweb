---
import '../styles/global.css'
import Navbar    from '@/components/layout/Navbar.astro'
import PlayerBar from '@/components/player/PlayerBar'
import { getLatestCloudcast } from '@/lib/mixcloud'
import { widgetSrc } from '@/lib/mixcloud'

interface Props {
  title?:       string
  description?: string
  ogImage?:     string
}

const {
  title       = 'Radio Elástica',
  description = 'Emisora online independiente desde Barcelona. Miércoles 11:11.',
  ogImage     = '/assets/logo-square.jpg',
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://radioelastica.com')
const latest = await getLatestCloudcast()
const iframeSrc = widgetSrc(latest?.key)
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/jpeg" href="/assets/logo-square.jpg" />
  <link rel="canonical" href={canonicalURL} />

  <title>{title === 'Radio Elástica' ? title : `${title} — Radio Elástica`}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Tipografía — Playfair Display -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />

  <!-- Mixcloud Widget API — se carga una sola vez aquí -->
  <script src="https://widget.mixcloud.com/media/js/widgetApi.js" is:inline></script>
</head>

<body class="bg-re-blue text-white font-display">

  <!-- NAV — fijo en la parte superior -->
  <Navbar />

  <!-- IFRAME de Mixcloud — fuera de la vista, se controla desde PlayerBar -->
  <iframe
    id="mc-widget"
    src={iframeSrc}
    style="width:1px;height:1px;position:absolute;left:-9999px"
    aria-hidden="true"
  ></iframe>

  <!-- CONTENIDO — zona con scroll entre nav y reproductor -->
  <main id="content" class="no-scrollbar">
    <slot />
  </main>

  <!-- BOTÓN HOME FLOTANTE — solo fuera de la home -->
  <a
    id="home-fab"
    href="/"
    class="fixed z-50 bottom-[104px] right-5
           w-12 h-12 rounded-full bg-white/10 border border-white/20
           flex items-center justify-center
           hover:bg-white/20 transition-colors
           hidden"
    aria-label="Volver al inicio"
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 10H5"/>
      <path d="M10 5l-5 5 5 5"/>
    </svg>
  </a>

  <!-- REPRODUCTOR — fijo en la parte inferior -->
  <PlayerBar client:load />

  <!-- Swipe derecha para volver a home (móvil) + mostrar/ocultar FAB -->
  <script is:inline>
    (function() {
      // Mostrar FAB solo fuera de la home, con href inteligente
      var fab = document.getElementById('home-fab');
      if (fab && window.location.pathname !== '/') {
        var path = window.location.pathname.replace(/\/$/, '');
        var parts = path.split('/').filter(Boolean);
        // /programas/slug → /programas, /residentes/slug → /residentes, resto → /
        if (parts.length >= 2 && (parts[0] === 'programas' || parts[0] === 'residentes')) {
          fab.href = '/' + parts[0];
        }
        fab.classList.remove('hidden');
      }

      // Swipe right → home
      var startX = 0;
      var startY = 0;
      document.addEventListener('touchstart', function(e) {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
      }, { passive: true });

      document.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - startX;
        var dy = Math.abs(e.changedTouches[0].clientY - startY);
        // Swipe horizontal > 100px, no mucho vertical, empieza desde el borde izquierdo
        if (dx > 100 && dy < 80 && startX < 40 && window.location.pathname !== '/') {
          window.location.href = fab ? fab.href : '/';
        }
      }, { passive: true });
    })();
  </script>

</body>
</html>
